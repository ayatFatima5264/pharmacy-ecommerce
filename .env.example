# Copy to .env.local and fill in. Never commit .env.local.
# Parsed and validated by src/config/env.ts at startup.

# --- Supabase ---
# Set ALL THREE or NONE (src/config/env.ts rejects a partial group). While
# unset, the app runs on the in-memory scaffold; once set, apply migrations
# with `npx supabase link` + `npx supabase db push`, then `npm run check:db`.
#
# URL + anon key are browser-safe by design: Supabase Auth is the identity
# provider, and RLS (0014_rls.sql, keyed on auth.uid()) is what user-bound
# clients are constrained by. The service role key is the exception below.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SERVER ONLY. Bypasses RLS entirely — full read/write on every table.
# Must never be referenced in a client component or prefixed NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# The Postgres password set at project creation. Used only by CLI scripts
# (npm run db:migrate) — never by the app itself.
SUPABASE_DB_PASSWORD=

# --- Email (Resend) ---
# Order emails are queued in the email_outbox table (never lost) and sent by
# the /api/cron/outbox drain. Without these vars the drain marks rows skipped
# and retries once configured.
RESEND_API_KEY=
EMAIL_FROM=

# Guards /api/cron/* endpoints (Bearer token, >=16 chars). Generate with:
# openssl rand -hex 24
CRON_SECRET=

# --- Application ---
# Absolute origin. Required for auth redirects, sitemap, and OG tags.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Staff bootstrap (used ONLY by `npm run seed:admin`) ---
# Creates the first admin account on a live Supabase project and mirrors the
# RBAC matrix into the database. The script refuses weak passwords (<12 chars).
# Sessions and password hashing are owned by Supabase Auth - there is no
# SESSION_SECRET and no custom hashing in this codebase.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# --- Payments (per docs/ARCHITECTURE.md §10.2 — pending gateway decision) ---
# JAZZCASH_MERCHANT_ID=
# JAZZCASH_PASSWORD=
# JAZZCASH_INTEGRITY_SALT=
