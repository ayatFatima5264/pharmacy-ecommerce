{
  "name": "healthcare-store",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "check:schema": "tsx scripts/schema-check.ts",
    "check:cart": "tsx scripts/cart-check.ts",
    "check:checkout": "tsx --conditions=react-server scripts/checkout-check.ts",
    "check:lab": "tsx --conditions=react-server scripts/lab-check.ts",
    "check:security": "tsx --conditions=react-server scripts/security-check.ts",
    "check:migrations": "tsx scripts/migrations-check.ts",
    "check:db": "tsx scripts/db-check.ts",
    "check": "npm run typecheck && npm run check:schema && npm run check:cart && npm run check:checkout && npm run check:lab && npm run check:security && npm run check:migrations && npm run check:db",
    "db:types": "npx supabase gen types typescript --linked --schema public > src/lib/supabase/types.gen.ts",
    "seed:admin": "tsx --conditions=react-server scripts/seed-admin.ts",
    "seed:catalog": "tsx --conditions=react-server scripts/seed-catalog.ts",
    "smoke": "tsx --conditions=react-server scripts/smoke-e2e.ts",
    "db:migrate": "tsx scripts/db-migrate.ts"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.3",
    "@supabase/supabase-js": "^2.110.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.474.0",
    "next": "^15.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "@types/node": "^22.10.7",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.1.6",
    "pg": "^8.22.0",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.23.1",
    "typescript": "^5.7.3"
  }
}
